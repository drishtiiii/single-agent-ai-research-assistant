# ==========================
# Application Settings
# ==========================
APP_NAME=Single Agent AI Research Assistant
DEBUG=True

# ==========================
# Logging
# ==========================
LOG_LEVEL=INFO

# ==========================
# LLM Configuration
# ==========================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your_openai_api_key

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# ==========================
# Runtime
# ==========================
REQUEST_TIMEOUT=60
MAX_RETRIES=3